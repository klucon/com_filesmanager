    "core_max": null,
    "python": ">=3.12",
    "database": [
      "mysql",
      "postgresql"
    ]
  },
  "package": {
    "python_package": "com_filesmanager",
    "entrypoint": "src.components.com_filesmanager",
    "setup_function": "setup",
    "admin_router": "admin.router",
    "web_views": [],
    "settings_url": "/admin/com_filesmanager"
  },
  "permissions": [
    {
      "key": "filesmanager.view",
      "label": "permissions.filesmanager.view"
    },
    {
      "key": "filesmanager.manage",
      "label": "permissions.filesmanager.manage"
    },
    {
      "key": "filesmanager.upload",
      "label": "permissions.filesmanager.upload"
    },
    {
      "key": "filesmanager.delete",
      "label": "permissions.filesmanager.delete"
    },
    {
      "key": "filesmanager.edit",
      "label": "permissions.filesmanager.edit"
    },
    {
      "key": "filesmanager.share",
      "label": "permissions.filesmanager.share"
    }
  ],
  "i18n": {
    "domain": "com_filesmanager",
    "locales_path": "i18n",
    "required_locales": [
      "cs_CZ",
      "en_GB"
    ]
  },
  "migrations": {
    "enabled": false,
    "path": "migrations"
  },
  "security": {
    "requires_signature": true,
    "capabilities": [
      "filesystem.write",
      "admin.routes"
    ]
  },
  "marketplace": {
    "category": "media",
    "tags": [
      "files",
      "filemanager",
      "media",
      "storage",
      "upload"
