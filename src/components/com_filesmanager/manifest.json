{
  "schema_version": "1.0",
  "name": "com_filesmanager",
  "type": "component",
  "vendor": "klucon",
  "extension_id": "klucon/com_filesmanager",
  "version": "0.1.0",
  "display_name": "Správce souborů",
  "display_name_key": "extensions.name.com_filesmanager",
  "description": "Moderní správce souborů: procházení, upload, přesun, kopírování, koš, hledání, náhledy, ZIP, textový editor, sdílecí odkazy a audit log.",
  "license": "MIT",
  "author": {
    "name": "KLUCON",
    "url": "https://klucon.cz"
  },
  "links": {
