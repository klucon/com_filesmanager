      "icon": "folder",
      "url": "/admin/com_filesmanager",
      "order": 140
    }
  },
  "min_cms_version": "0.1.0",
  "categories": [
    "media"
  ],
  "supported_locales": [
    "cs_CZ",
    "en_GB"
  ],
  "changelog": "První vydání: procházení, upload (drag&drop), přesun/kopírování, koš s obnovou, hledání, náhledy obrázků a PDF, ZIP/rozbalení, textový editor, sdílecí odkazy s expirací a audit log. ACL na úrovni rolí.",
  "routes": {
    "admin": {
      "enabled": true,
      "prefix": "/admin/com_filesmanager",
      "nav_label": "extensions.name.com_filesmanager",
      "nav_icon": "folder",
